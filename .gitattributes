# Handle line endings consistently (prevents CRLF warnings on Windows)
* text=auto

# Force LF for text files used in web/static (HTML, JS, CSS, JSON, PY, MD)
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.svg text eol=lf

# Keep CRLF for Windows-specific scripts if any
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.exe binary
*.dll binary
*.zip binary
*.pdf binary