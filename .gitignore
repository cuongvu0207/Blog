# Secrets & private runtime data (never commit)
users.json
config.json
domain.json

# Personal uploads - include the initial demo images so the site works out-of-the-box after clone.
# For new uploads during local dev (if using server.py), they can be added to .gitignore locally or committed if you want them in the static site on Git/Vercel.
# uploads/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Vercel local
.vercel/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp

# Future / optional
node_modules/
venv/
.env
*.log

# Cloudflared binary (large, local only)
tools/cloudflared.exe

# Keep the start scripts committed - they are useful for anyone cloning the project
# (the *.bat files are intentionally NOT ignored)